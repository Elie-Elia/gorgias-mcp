# ============================================
# Local Development Configuration
# ============================================
ENVIRONMENT=local

# ============================================
# Gorgias API Credentials
# ============================================
# Your Gorgias subdomain (e.g. "casadilumo"), full domain ("casadilumo.gorgias.com"),
# or full URL ("https://casadilumo.gorgias.com").
GORGIAS_DOMAIN=your-subdomain

# Email of the Gorgias REST API user
GORGIAS_EMAIL=admin@example.com

# REST API key from Gorgias > Settings > REST API
GORGIAS_API_KEY=your_api_key_here

# Access level — controls which tools are exposed.
#   readonly: only read/search/list tools
#   agent:    readonly + reply / close / tag / reassign (typical CS chatbot)
#   admin:    everything (default if unset)
GORGIAS_ACCESS_LEVEL=agent

# ============================================
# Gumstack Configuration (set by gumstack in production)
# ============================================
GUMSTACK_SERVER_ID=gorgias-mcp-server
# GUMSTACK_BACKEND_URL=https://api.gumstack.com
# GUMLOOP_BACKEND_URL=https://api.gumloop.com
